<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MQTT_StringToFile"
        xmlns:MQTT_Manager_jjo="clr-namespace:MQTT_Manager_jjo;assembly=MQTT_Manager_jjo" 
        x:Class="MQTT_StringToFile.MainWindow"
        mc:Ignorable="d"
        Title="MQTT String → File" Height="600" Width="900">

    <Grid Margin="5">
        <StackPanel Orientation="Vertical">

            <!-- ── MQTT Client ── -->
            <MQTT_Manager_jjo:MQTT_Manager_UC x:Name="mqtt_client" Margin="10,10,10,0" VerticalAlignment="Top" />

            <!-- ── Options globales ── -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Margin="2,5,2,5" Padding="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0" Content="Répertoire de base :" VerticalContentAlignment="Center"/>
                    <TextBox Grid.Column="1" 
                             Text="{Binding _baseDirectory, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                             Margin="2" VerticalContentAlignment="Center"/>
                    <Image Grid.Column="2" Source="/Resource/folder.png" Height="25" Margin="2,0"
                           MouseDown="_btn_selectDirectory_Click" 
                           RenderOptions.BitmapScalingMode="Fant"
                           ToolTip="Choisir le répertoire de base"/>
                    <CheckBox Grid.Column="3" Margin="10,0,5,0" 
                              Content="DateTime" VerticalContentAlignment="Center"
                              IsChecked="{Binding _dateTime}"/>
                    <TextBox Grid.Column="4" Margin="2,0" 
                             Text="{Binding _dateTime_format}" 
                             VerticalContentAlignment="Center" 
                             Width="170" HorizontalContentAlignment="Center"/>
                    <TextBox Grid.Column="5" Margin="2,0"
                             Text="{Binding _separation}"
                             VerticalContentAlignment="Center"
                             Width="30" HorizontalContentAlignment="Center"
                             ToolTip="Séparateur"/>
                </Grid>
            </Border>

            <!-- ── Bouton Ajouter un topic ── -->
            <Button Content="＋  Ajouter un topic → fichier"
                    HorizontalAlignment="Left"
                    Margin="2,0,2,5" Padding="10,4"
                    Click="_btn_addTopic_Click"/>

            <!-- ── Liste des topics ── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="350">
                <StackPanel x:Name="_topicsPanel" Orientation="Vertical"/>
            </ScrollViewer>

        </StackPanel>
    </Grid>
</Window>
