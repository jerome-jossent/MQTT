<UserControl x:Class="MQTT_Explorer.Topic_Data_UC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MQTT_Explorer"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="5,0,0,0" Orientation="Horizontal">
            <TextBlock Text="{Binding _data.topic.topic}" FontWeight="Bold" Margin="5,0"/>
            <TextBlock Text="{Binding _data.date}" Margin="5,0"/>
            <TextBlock Text="{Binding _data.index}" Margin="5,0"/>
        </StackPanel>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Image Margin="5,0,20,0" Source="/Images/Lecture.png" Stretch="UniformToFill" 
                   MouseDown="TEST" ToolTip="TEST"
                   Height="20" Width="20" RenderOptions.BitmapScalingMode="Fant" />
            
            <Image Margin="5,0,0,0" Source="/Images/checks.png" Stretch="UniformToFill" 
                   MouseDown="SetFilter" ToolTip="Filter"
                   Height="20" Width="20" RenderOptions.BitmapScalingMode="Fant" />
            
            <Image Margin="5,0,0,0" Source="/Images/copy_to_clipboard.png" Stretch="UniformToFill" 
                   MouseDown="Copy_to_clipboard" ToolTip="Copy topic to clipboard"
                   Height="20" Width="20" RenderOptions.BitmapScalingMode="Fant" />
            
            <Image Margin="5,0,0,0" Source="/Images/Lecture.png" Stretch="UniformToFill" 
                   MouseDown="Publish_again" ToolTip="Publish this data on the same topic again"
                   Height="20" Width="20" RenderOptions.BitmapScalingMode="Fant" />

        </StackPanel>

        <TreeView Grid.Row="1" x:Name="trv" MouseDown="trv_click">
        </TreeView>
        <TextBox Grid.Row="1" x:Name="txt"/>
    </Grid>

</UserControl>
