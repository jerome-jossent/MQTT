<UserControl x:Class="MQTT_Explorer.Publish_UC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MQTT_Explorer"
             mc:Ignorable="d" 
             d:DesignHeight="150" d:DesignWidth="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" MinHeight="18"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*" MinHeight="18"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Topic"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="_topic" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Value"/>
            <TextBox Grid.Row="2" Grid.Column="1"  TextWrapping="Wrap" 
                         x:Name="_payload" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <CheckBox Grid.Column="0" Content="Retain" x:Name="_retain"/>
            <Image Grid.Column="2" Source="/Images/Upload.png" Width="20" Height="20" MouseDown="Publish_Click" />
        </Grid>

    </Grid>
</UserControl>
