<Window x:Class="MQTT_Messages_Generator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MQTT_Messages_Generator"
        mc:Ignorable="d"
        
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"

        Loaded="Window_Loaded" Unloaded="Window_Unloaded"
        
        Title="MainWindow" Height="186" Width="250">
    <Window.Resources>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
            <xctk:IntegerUpDown Value="{Binding _occurences}" Margin="5" Height="36"  Width="80"  />
            <Button x:Name="_btn_start_stop" Content="Start" HorizontalAlignment="Left" Height="36" Margin="5"  Width="50" Click="Button_Click"/>
            <Grid Height="36" VerticalAlignment="Center">
                <Label Content="Idle" VerticalContentAlignment="Center" Foreground="Gray" Visibility="{local:Not {Binding _run}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <Label Content="Running" VerticalContentAlignment="Center" Foreground="Gray" Visibility="{Binding _run, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>

        </StackPanel>
        <Button x:Name="_btn_2" Content="Start" Height="36"  Width="50" Click="Button_2_Click" Margin="100,51,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>



    </Grid>
</Window>
