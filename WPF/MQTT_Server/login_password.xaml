<UserControl x:Class="MQTT_Server.login_password"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MQTT_Server"
             mc:Ignorable="d" 
             d:DesignHeight="25" d:DesignWidth="400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="25"/>
        </Grid.ColumnDefinitions>

        <Image Grid.Column="0" Height="15" Margin="0,0,5,0" Source="/Resources/toggle_off2.png" MouseDown="ON" RenderOptions.BitmapScalingMode="Fant" />
        <Image Grid.Column="0" Height="15" Margin="0,0,5,0" Source="/Resources/toggle_on2.png" x:Name="_btn_off" MouseDown="OFF" RenderOptions.BitmapScalingMode="Fant" />

        <TextBlock Grid.Column="1" x:Name="_tbk_login"/>
        
        <TextBlock Grid.Column="2" x:Name="_tbk_password"/>

        <Image Grid.Column="3" Height="20" Source="/Resources/Corbeille.png" MouseDown="Delete" RenderOptions.BitmapScalingMode="Fant" />
    </Grid>
</UserControl>
