<UserControl x:Class="MQTT_Server.Client"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MQTT_Server"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" x:Name="_tbk_date" Foreground="Gray"/>
        <TextBlock Grid.Column="1" x:Name="_tbk_ID" Margin="5,0"/>
        <TextBlock Grid.Column="2" x:Name="_tbk_username" Foreground="Blue" HorizontalAlignment="Right"/>
    </Grid>
</UserControl>
