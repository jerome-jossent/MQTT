<Window x:Class="MQTT_Server.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MQTT_Server"
        mc:Ignorable="d"
        Loaded="Window_Loaded" Unloaded="Window_Unloaded"
        Title="MQTT Server" Height="450" Width="800">
    <Grid>
        <TabControl SelectedIndex="1">

            <TabItem Header="Settings" x:Name="_tb_Settings">
                <Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Image Margin="3,0" ToolTip="Save settings" MouseDown="btn_save" Source="/Resources/save.png" RenderOptions.BitmapScalingMode="Fant" HorizontalAlignment="Right" Width="30" Height="30" VerticalAlignment="Top" />
                        <Image Margin="3,0" ToolTip="Load settings" MouseDown="btn_load" Source="/Resources/load.png" RenderOptions.BitmapScalingMode="Fant" HorizontalAlignment="Right" Width="30" Height="30" VerticalAlignment="Top" />
                        <Image Margin="3,0" MouseDown="btn_reset" Source="/Resources/Reboot.png" RenderOptions.BitmapScalingMode="Fant" HorizontalAlignment="Right" Width="30" Height="30" VerticalAlignment="Top" />
                    </StackPanel>


                    <TextBlock Text="Port" Margin="25,13,0,0" Height="25"   HorizontalAlignment="Left" Width="53" VerticalAlignment="Top"/>

                    <TextBox Text="{Binding _port_string}" Margin="62,10,0,0" Height="25" 
                             VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                             HorizontalAlignment="Left" Width="53" VerticalAlignment="Top"/>

                    <GroupBox Margin="0,49,0,0"  >
                        <GroupBox.Header>
                            <TextBlock Text="Authentication" Foreground="CornflowerBlue" FontWeight="Bold" />
                        </GroupBox.Header>
                        <Grid Margin="5,10,5,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,5">
                                <CheckBox Content="Allow anonymous client (no login or password needed)"
                                          IsChecked="{Binding _allow_anonymous, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Login" Margin="5,0" Width="50" VerticalAlignment="Center" TextAlignment="Right" />
                                <TextBox Grid.Column="1" x:Name="_tbx_login" Margin="5,0" Width="200" VerticalContentAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="Password" Margin="5,0" Width="60" TextAlignment="Right" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="3" x:Name="_tbx_password" Margin="5,0" Width="200" VerticalContentAlignment="Center" />
                                <Image Grid.Column="4" MouseDown="btn_login_mdp_add" Source="/Resources/Plus.png" Height="25" RenderOptions.BitmapScalingMode="Fant" />
                            </Grid>

                            <ListView Grid.Row="2" Margin="0,5" HorizontalContentAlignment="Stretch" ItemsSource="{Binding _loginPasswords}"
                                      SelectionChanged="ListView_SelectionChanged"/>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="DebugMessages">
                <ListBox Grid.Row="1" ItemsSource="{Binding DebugMessages, UpdateSourceTrigger=PropertyChanged}" 
                    Foreground="#FFFFFFFF" Background="Black"                             
                    ScrollViewer.CanContentScroll="False"  />
            </TabItem>


            <TabItem Header="Connected clients">
                <ListView ItemsSource="{Binding _clients}" HorizontalContentAlignment="Stretch" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>
